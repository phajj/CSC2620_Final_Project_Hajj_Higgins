@startuml UseCase
left to right direction

actor "User" as U
actor "Server" as S

rectangle "Authentication"{
    usecase "Register" as UC0
    usecase "Login" as UC1
    usecase "Logout" as UC2
    usecase "Delete Account" as UC3
}

rectangle "Voice Commands"{
    usecase "Play ..." as UC4
}

rectangle "Save History"{
    usecase "Save command history." as UC5
}

U --> UC0
U --> UC1
U --> UC2
U --> UC3

U --> UC4

U --> UC5
@enduml